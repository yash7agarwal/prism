# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
TELEGRAM_BOT_TOKEN=              # from @BotFather on Telegram

# ── Optional ──────────────────────────────────────────────────────────────────
FIGMA_API_TOKEN=                 # personal token from figma.com/settings  (was FIGMA_ACCESS_TOKEN)
FIGMA_ACCESS_TOKEN=              # legacy alias — use FIGMA_API_TOKEN
TELEGRAM_CHAT_ID=                # if you want to restrict bot to your chat ID only
UAT_ACCOUNTS_FILE=accounts.json  # path to accounts JSON
UAT_FEATURE=                     # default feature desc used when /run has no args

# ── Device (leave blank for emulator auto-detect) ─────────────────────────────
DEVICE_SERIAL=                   # e.g. emulator-5554 or physical device serial

# ── Daily digest push (v0.10.5) ───────────────────────────────────────────────
# If set, the orchestrator's "digest" agent pushes a daily summary to this
# Telegram chat. If unset, digest is generated on-demand only (/intel digest).
PRISM_DIGEST_CHAT_ID=
