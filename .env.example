# Prism — environment variable template
# Copy this to `.env` and fill in the values. For Railway, set each one
# in the service's Variables tab (do not commit `.env` to git).

# ─── LLM providers (at least ONE is required) ─────────────────────────────────
# Claude is preferred for synthesis (highest fidelity). Gemini is the
# fallback. Groq (free 14,400 RPD) is used when PRISM_SYNTH_CHEAP=1 OR when
# the bigger models are exhausted.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: force a single provider. Leave blank to use the cascade
# (Claude → Gemini → Groq). Values: "claude" | "gemini"
LLM_PROVIDER=

# Optional: flip synthesis to Groq-first. Use on budget-conscious runs;
# reverses the v0.11.0 correctness-first default. Value: "1" to enable.
PRISM_SYNTH_CHEAP=

# ─── Web research (at least ONE is recommended) ───────────────────────────────
# Tavily is the primary provider (1000 free searches/month). Brave is the
# secondary. DuckDuckGo is the unauthenticated fallback and needs no key.
TAVILY_API_KEY=
BRAVE_API_KEY=

# ─── Telegram bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather to get the token. The chat ID is your personal
# chat with the bot — send it any message, then GET
# https://api.telegram.org/bot<TOKEN>/getUpdates to read your chat id.
TELEGRAM_BOT_TOKEN=
# Either name works — PM_CHAT_ID takes precedence if both set. Used by:
#   - F1 research digest after each industry_research run
#   - F2 quality-regression alerts
TELEGRAM_PM_CHAT_ID=
TELEGRAM_CHAT_ID=

# ─── Inter-service URL (Railway / split deploy) ───────────────────────────────
# How the bot reaches the API. Defaults to http://localhost:8100 for dev.
# On Railway: http://<api-service>.railway.internal:<PORT>
PRISM_API_URL=http://localhost:8100

# ─── Loupe (UAT sibling) ──────────────────────────────────────────────────────
# Where Prism reads UAT evidence from for /prd synthesis. Set to the Loupe
# FastAPI URL (default: localhost:8001). On Railway, use the Loupe service's
# internal URL once it's deployed. Leave blank to disable Loupe integration —
# PRDs will be generated with market context only.
LOUPE_API_URL=http://localhost:8001
LOUPE_API_TOKEN=                     # optional; future auth

# ─── Orchestrator daemon auto-start ───────────────────────────────────────────
# In production (Railway), set to "1" so the FastAPI startup hook launches
# the 6h research-scheduler daemon + the 24h quality-regression check.
# In local dev, leave unset — auto-starting on every uvicorn restart would
# spam APIs. Trigger runs manually via the UI or /intel commands instead.
PRISM_AUTO_DAEMON=
